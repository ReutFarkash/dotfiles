
# Src: https://github.com/sapegin/dotfiles/blob/dd063f9c30de7d2234e8accdb5272a5cc0a3388b/includes/bash_prompt.bash


# Clean and minimalistic Bash prompt
# Author: Artem Sapegin, sapegin.me
# 
# Inspired by: https://github.com/sindresorhus/pure & https://github.com/dreadatour/dotfiles/blob/master/.bash_profile
#
# Notes:
# - $local_username - username you don’t want to see in the prompt - can be defined in ~/.bashlocal : `local_username="admin"`
# - Colors ($RED, $GREEN) - defined in ../tilde/bash_profile.bash
#

if [ "$DEBUG" == true ]; then
    scriptpath="${CUR_DIR}/${BASH_ARGV[0]}"
    echo "running $scriptpath"
fi






# Highlight the user name when logged in as root.
if [[ "${USER}" == "root" ]]; then
	alias user_theme=user_root_theme;
else
	alias user_theme=user_nonroot_theme;
fi;

# Highlight the hostname when connected via SSH.
if [[ "${SSH_TTY}" ]]; then
	alias host_theme=host_ssh_theme;
else
	alias host_theme=host_reg_theme;
fi;



prompt_git_func() {
		if [ "$DEBUG" == true ]; then
			echo "running prompt_git_func" >&2
		fi

		branch_name=$(fancygit_git_get_branch)
		if [ "" = "$branch_name" ]
		then
			# No branch found, so we're not in a git repo.
			return;
		fi

		if [ "HEAD" = "$branch_name" ]
		then
			branch_name=$(fancygit_git_get_tag)
		fi
		
		prompt_branch="$ICON_GIT_BRANCH$(fancygit_git_get_branch_icon ${branch_name})$branch_name"
		stats_prompt="$(fancygit_get_poor_notification_area ${branch_name})"  #"$(fancygit_get_git_stats_prompt)"
		alias git_theme=git_clean_theme
		_git_prompt="$prompt_branch$stats_prompt"
		echo -e "$(git_theme $prompt_branch)$(git_theme $stats_prompt)"
	}


function prompt_command() {
	if [ "$DEBUG" == true ]; then
		echo "running prompt_command" >&2
	fi
	# Local or SSH session?
	local remote=
	[ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ] && remote=1

	# Virtualenv
	local venv_prompt=
	if [ -n "$VIRTUAL_ENV" ]; then
		venv_prompt="($prompt_venv_symbol$(basename $VIRTUAL_ENV))"
		venv_prompt="$(venv_theme $venv_prompt)"
	fi

	# Conda
	local conda_prompt=
	if [ ! -z "$CONDA_DEFAULT_ENV" ]
	then
		conda_prompt="$(conda_theme $prompt_conda_symbol$CONDA_DEFAULT_ENV)"
	fi

	# Only show username if not default
	local user_prompt=
	[ "$USER" != "$local_username" ] && user_prompt="$(user_theme $USER)"

	# Show hostname inside SSH session
	local host_prompt=
	[ -n "$remote" ] && host_prompt="@$(host_theme $HOSTNAME)"

	local cur_path="$(dir_theme $(shortenPath $(pwd) $DIR_PATH_LEN))"

	first_line="$venv_prompt$conda_prompt $user_prompt $host_prompt$ICON_DIR $cur_path$git_prompt "
	
	if [ "$PRINTGIT" == true ]; then
    	first_line+="$(prompt_git_func )";
	fi
	

	# Text (commands) inside \[...\] does not impact line length calculation which fixes stange bug when looking through the history
	# $? is a status of last command, should be processed every time prompt prints
	second_line="\`if [ \$? = 0 ]; then echo \[\$CYAN\]; else echo \[\$RED\]; fi\`\$prompt_symbol\[\$NOCOLOR\] "
	PS1="\n$first_line\n$second_line"
	# PS1=${PS1:+"$PS1; "}'printf "\e]9;9;%s\e\\" "$(wslpath -w "$PWD")"'
	export PS1;

	# Multiline command
	# PS2="($ cyan_fg $prompt_symbol) "
	PS2="$(cyan_fg prompt_symbol)"
	export PS2;

	# Terminal title
	local title="$(basename "$PWD")"
	[ -n "$remote" ] && title="$title \xE2\x80\x94 $HOSTNAME"
	echo -ne "\033]0;$title"; echo -ne "\007"

	if [ "$DEBUG" == true ]; then
		echo "end of .bash_prompt $(date +%M,%S)" >&2
	fi
}

# Show awesome prompt only if Git is istalled
command -v git >/dev/null 2>&1 && PROMPT_COMMAND=prompt_command

