
if [ "$DEBUG" == true ]; then
    scriptpath="${CUR_DIR}/${BASH_ARGV[0]}"
    echo "running $scriptpath"
fi


if [[ -z "${DEBUG+x}" ]]; then
    [ -n "$PS1" ] && echo "Setting DEBUG=false"
    export DEBUG=false
fi

if [[ ! -v PRINTGIT ]]; then
    [ -n "$PS1" ] && echo "Setting PRINTGIT=false"
    export PRINTGIT=false
fi
